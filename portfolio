<style>
:root{
  --bg:#06060e;--card:#111128;
  --a1:#7c3aed;--a2:#06b6d4;--a3:#f59e0b;
  --text:#e2e8f0;--muted:#94a3b8;--border:rgba(124,58,237,.22);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:
  radial-gradient(ellipse 70% 50% at 15% 5%,rgba(124,58,237,.18) 0,transparent 60%),
  radial-gradient(ellipse 55% 40% at 85% 85%,rgba(6,182,212,.14) 0,transparent 60%),
  radial-gradient(ellipse 35% 25% at 55% 35%,rgba(245,158,11,.07) 0,transparent 50%);
  pointer-events:none;z-index:0}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;
  justify-content:space-between;padding:1rem 3rem;
  background:rgba(6,6,14,.8);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.88rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--a2)}
.btn-hire{display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1.4rem;
  border-radius:50px;font-family:'Syne',sans-serif;font-size:.82rem;font-weight:700;
  text-decoration:none;background:linear-gradient(135deg,var(--a1),#4f46e5);color:#fff;border:none;
  box-shadow:0 0 20px rgba(124,58,237,.5);transition:all .25s;animation:pulse-btn 2.5s infinite}
.btn-hire:hover{transform:translateY(-2px) scale(1.04);box-shadow:0 0 38px rgba(124,58,237,.8)}
@keyframes pulse-btn{0%,100%{box-shadow:0 0 20px rgba(124,58,237,.5)} 50%{box-shadow:0 0 40px rgba(124,58,237,.8)}}

#hero{min-height:100vh;display:flex;align-items:center;padding:7rem 3rem 4rem;gap:4rem;position:relative;z-index:1}
.hero-text{flex:1}
.badge{display:inline-block;padding:.3rem 1rem;border-radius:50px;
  border:1px solid rgba(6,182,212,.38);background:rgba(6,182,212,.07);
  color:var(--a2);font-size:.74rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.4rem}
.hero-name{font-family:'Syne',sans-serif;font-size:clamp(2.6rem,5vw,4.4rem);
  font-weight:800;line-height:1.05;letter-spacing:-1.5px;margin-bottom:.4rem}
.hero-name span{background:linear-gradient(135deg,var(--a1) 20%,var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-role{font-family:'Syne',sans-serif;font-size:1.1rem;color:var(--a3);font-weight:600;margin-bottom:1.2rem}
.hero-bio{color:var(--muted);line-height:1.75;max-width:520px;font-size:.96rem;margin-bottom:2rem}
.hero-ctas{display:flex;gap:1rem;flex-wrap:wrap}
.btn-primary{padding:.72rem 1.8rem;border-radius:50px;
  background:linear-gradient(135deg,var(--a1),var(--a2));color:#fff;
  text-decoration:none;font-family:'Syne',sans-serif;font-weight:700;font-size:.86rem;
  transition:all .25s;box-shadow:0 4px 20px rgba(124,58,237,.32)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(124,58,237,.55)}
.btn-outline{padding:.72rem 1.8rem;border-radius:50px;border:1.5px solid var(--border);
  color:var(--text);text-decoration:none;font-family:'Syne',sans-serif;font-weight:600;
  font-size:.86rem;transition:all .25s}
.btn-outline:hover{border-color:var(--a2);color:var(--a2)}

/* PHOTO */
.photo-wrap{flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center}
.photo-ring{width:320px;height:320px;border-radius:50%;padding:5px;
  background:linear-gradient(135deg,var(--a1),var(--a2),var(--a3),var(--a1));
  box-shadow:0 0 60px rgba(124,58,237,.5),0 0 100px rgba(6,182,212,.2);
  animation:hue-spin 6s linear infinite;flex-shrink:0}
@keyframes hue-spin{to{filter:hue-rotate(360deg)}}
.photo-inner{width:100%;height:100%;border-radius:50%;overflow:hidden;border:5px solid var(--bg)}
.photo-inner img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}
.pill{position:absolute;display:flex;align-items:center;gap:.5rem;padding:.48rem .95rem;
  border-radius:50px;background:rgba(10,10,28,.92);border:1px solid var(--border);
  backdrop-filter:blur(12px);font-size:.75rem;font-weight:600;white-space:nowrap;
  animation:float 3s ease-in-out infinite}
.pill.p1{bottom:10px;left:-50px;animation-delay:0s}
.pill.p2{top:20px;right:-55px;animation-delay:1.3s}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
@keyframes float{0%,100%{transform:translateY(0)} 50%{transform:translateY(-9px)}}

section{position:relative;z-index:1}
.sec-wrap{padding:5rem 3rem;max-width:1100px;margin:0 auto}
.sec-head{text-align:center;margin-bottom:3.5rem}
.sec-label{display:inline-block;padding:.28rem .95rem;border-radius:50px;
  border:1px solid rgba(6,182,212,.32);background:rgba(6,182,212,.06);
  color:var(--a2);font-size:.7rem;font-weight:700;letter-spacing:.14em;
  text-transform:uppercase;margin-bottom:.85rem}
.sec-title{font-family:'Syne',sans-serif;font-size:clamp(1.9rem,3vw,2.7rem);font-weight:800;letter-spacing:-.5px}
.sec-title span{background:linear-gradient(135deg,var(--a1),var(--a2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent}

.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.4rem}
.sk-card{background:var(--card);border:1px solid var(--border);border-radius:20px;
  padding:1.7rem;transition:all .3s;position:relative;overflow:hidden}
.sk-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:20px 20px 0 0}
.sk-card.c1::before{background:linear-gradient(90deg,var(--a1),var(--a2))}
.sk-card.c2::before{background:linear-gradient(90deg,var(--a2),var(--a3))}
.sk-card.c3::before{background:linear-gradient(90deg,var(--a3),var(--a1))}
.sk-card:hover{transform:translateY(-6px);border-color:rgba(124,58,237,.45);box-shadow:0 22px 50px rgba(124,58,237,.11)}
.sk-icon{font-size:1.9rem;margin-bottom:.85rem}
.sk-cat{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem}
.sk-name{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;margin-bottom:.9rem}
.tags{display:flex;flex-wrap:wrap;gap:.45rem}
.tag{padding:.22rem .65rem;border-radius:50px;font-size:.72rem;font-weight:500;
  background:rgba(124,58,237,.11);border:1px solid rgba(124,58,237,.22);color:var(--text)}

.proj-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:1.7rem}
.proj-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:1.9rem;transition:all .3s;position:relative;overflow:hidden}
.proj-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px}
.proj-card.pc1::after{background:linear-gradient(90deg,var(--a1),var(--a2))}
.proj-card.pc2::after{background:linear-gradient(90deg,var(--a2),var(--a3))}
.proj-card.pc3::after{background:linear-gradient(90deg,var(--a3),var(--a1))}
.proj-card:hover{transform:translateY(-8px);box-shadow:0 26px 60px rgba(124,58,237,.14)}
.proj-dur{display:inline-flex;align-items:center;gap:.4rem;padding:.23rem .7rem;border-radius:50px;
  font-size:.7rem;font-weight:600;color:var(--a2);background:rgba(6,182,212,.09);
  border:1px solid rgba(6,182,212,.22);margin-bottom:1rem}
.proj-title{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:.7rem;line-height:1.3}
.proj-desc{color:var(--muted);font-size:.86rem;line-height:1.7;margin-bottom:1.1rem}
.tool-tags{display:flex;flex-wrap:wrap;gap:.38rem}
.ttag{padding:.18rem .55rem;border-radius:6px;font-size:.68rem;font-weight:600;
  background:rgba(245,158,11,.09);border:1px solid rgba(245,158,11,.22);color:var(--a3)}

.edu-tl{display:flex;flex-direction:column;gap:1.4rem;position:relative;max-width:800px;margin:0 auto}
.edu-tl::before{content:'';position:absolute;left:22px;top:0;bottom:0;width:2px;
  background:linear-gradient(to bottom,var(--a1),var(--a2),transparent)}
.edu-item{display:flex;gap:1.4rem;align-items:flex-start}
.edu-dot{flex-shrink:0;width:46px;height:46px;border-radius:50%;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  display:flex;align-items:center;justify-content:center;font-size:1.1rem;
  box-shadow:0 0 18px rgba(124,58,237,.4);position:relative;z-index:1}
.edu-box{flex:1;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.35rem 1.55rem;transition:all .25s}
.edu-box:hover{border-color:rgba(6,182,212,.35);box-shadow:0 8px 28px rgba(6,182,212,.07)}
.edu-deg{font-family:'Syne',sans-serif;font-weight:700;font-size:.98rem;margin-bottom:.22rem}
.edu-sch{color:var(--muted);font-size:.82rem;margin-bottom:.55rem}
.edu-meta{display:flex;gap:.85rem;flex-wrap:wrap}
.edu-b1{padding:.18rem .65rem;border-radius:50px;font-size:.7rem;font-weight:600;
  background:rgba(124,58,237,.11);border:1px solid rgba(124,58,237,.22);color:var(--a1)}
.edu-b2{padding:.18rem .65rem;border-radius:50px;font-size:.7rem;font-weight:600;
  background:rgba(6,182,212,.09);border:1px solid rgba(6,182,212,.22);color:var(--a2)}

.certs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.1rem}
.cert-card{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.1rem 1.35rem;display:flex;align-items:center;gap:.9rem;transition:all .25s}
.cert-card:hover{border-color:rgba(245,158,11,.38);transform:translateX(4px)}
.cert-ico{flex-shrink:0;width:38px;height:38px;border-radius:10px;
  background:linear-gradient(135deg,var(--a3),var(--a1));
  display:flex;align-items:center;justify-content:center;font-size:.95rem}
.cert-name{font-size:.82rem;font-weight:500;line-height:1.35}

.act-list{display:flex;flex-direction:column;gap:.95rem;max-width:800px;margin:0 auto}
.act-item{display:flex;align-items:center;gap:1.15rem;background:var(--card);
  border:1px solid var(--border);border-radius:14px;padding:1rem 1.45rem;transition:all .25s}
.act-item:hover{border-color:rgba(124,58,237,.38);transform:translateX(6px)}
.act-n{width:36px;height:36px;border-radius:8px;flex-shrink:0;
  background:linear-gradient(135deg,var(--a1),var(--a2));
  display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.act-t{font-size:.9rem;line-height:1.5}

.contact-box{background:var(--card);border:1px solid var(--border);border-radius:24px;
  padding:3rem;position:relative;overflow:hidden;text-align:center;max-width:760px;margin:0 auto}
.contact-box::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 55% at 50% 0%,rgba(124,58,237,.09),transparent 58%);pointer-events:none}
.clinks{display:flex;flex-wrap:wrap;justify-content:center;gap:.95rem;margin-top:2rem}
.clink{display:inline-flex;align-items:center;gap:.55rem;padding:.65rem 1.35rem;border-radius:50px;
  text-decoration:none;font-size:.82rem;font-weight:600;border:1.5px solid var(--border);
  color:var(--text);transition:all .25s;background:rgba(255,255,255,.02)}
.clink:hover{border-color:var(--a1);color:var(--a1);transform:translateY(-2px);box-shadow:0 8px 24px rgba(124,58,237,.18)}

footer{text-align:center;padding:1.8rem;color:var(--muted);font-size:.78rem;
